# Required
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=your_database_id

# Recommended
SITE_URL=https://your-domain.example

# Optional Notion property name overrides
# Comma-separated candidate names are checked in order.
# NOTION_TITLE_PROPERTY_NAMES=Name,Title,标题
# NOTION_CATEGORY_PROPERTY_NAMES=Category,分类
# NOTION_TAGS_PROPERTY_NAMES=Tags,Tag,标签
# NOTION_EXCERPT_PROPERTY_NAMES=Excerpt,Summary,Description,摘要
# NOTION_DATE_PROPERTY_NAMES=Date,Published At,Publish Date,发布日期,发布时间
# NOTION_READ_TIME_PROPERTY_NAMES=ReadTime,Read Time,Reading Time,阅读时间,阅读时长

# Cache and request tuning
DATABASE_METADATA_TTL_MS=300000
PUBLIC_PAGE_SUMMARY_CACHE_TTL_MS=120000
PUBLIC_POST_CACHE_TTL_MS=60000
NOTION_REQUEST_TIMEOUT_MS=12000
NOTION_BLOCK_CHILD_CONCURRENCY=4
IMAGE_PROXY_TIMEOUT_MS=10000
IMAGE_PROXY_MAX_BYTES=8388608
IMAGE_PROXY_MAX_REDIRECTS=4

# Public content policy
# By default, the whole configured Notion database is public, matching v2.5 behavior.
# Keep drafts in another database; public/published fields are intentionally ignored.

# Local debugging only
EXPOSE_PUBLIC_ERROR_DETAILS=false
